# Block direct web access to sensitive files (Apache 2.4)
# Only api.php (and the app's static assets one level up) should be reachable.

# Secrets / config
<FilesMatch "^(config\.php|config\.sample\.php)$">
  Require all denied
</FilesMatch>

# SQL dumps
<FilesMatch "\.(sql|sqlite|db)$">
  Require all denied
</FilesMatch>

# Server-side directories that must never be web-served.
# De-anchored (^|/) so it also matches subpath deploys (e.g. /tracker/server/lib/…),
# not just a root-anchored /server/…. Backed by dir-local `Require all denied`
# .htaccess in each of these dirs in case mod_alias/RedirectMatch is unavailable.
RedirectMatch 404 (^|/)server/(lib|data|jwks_cache)/
