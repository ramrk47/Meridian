# secrets & per-user server state
server/config.php
server/data/*.json
server/data/legacy/*.json
# dev SQLite database (never commit user data)
server/data/*.sqlite
server/data/*.sqlite-*
# cached Google JWKS (regenerated at runtime)
server/jwks_cache/*.json

# dev / editor / OS
.claude/
.DS_Store
*.log
node_modules/

# bulky raw page saves / re-dropped archives (keep CSVs + manifests, not these)
_raw/NewPlatforms/*.html
_raw/NewPlatforms/*_files/
_raw/NewPlatforms/*.zip

# ultracode mapping-audit work inputs (not committed)
.mapwork/
__pycache__/
